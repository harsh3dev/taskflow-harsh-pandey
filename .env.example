# Application
APP_ENV=development

# Backend
BACKEND_PORT=8080
JWT_SECRET=replace-me-with-at-least-32-characters
JWT_SIGNING_KEYS=default:replace-me-with-at-least-32-characters
JWT_ACTIVE_KEY_ID=default
JWT_ISSUER=taskflow
JWT_AUDIENCE=taskflow-api
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h
BCRYPT_COST=12

# Frontend
FRONTEND_PORT=3000
VITE_API_BASE_URL=/api

# PostgreSQL
POSTGRES_DB=taskflow
POSTGRES_USER=taskflow
POSTGRES_PASSWORD=taskflow
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# For local development outside Docker use localhost.
# docker-compose overrides this automatically using the postgres service name.
DATABASE_URL=postgres://taskflow:taskflow@localhost:5432/taskflow?sslmode=disable

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Notifications (email via SMTP)
# Set NOTIFICATIONS_ENABLED=true to activate the notification worker.
# For local testing use Mailhog: docker run -p 1025:1025 -p 8025:8025 mailhog/mailhog
NOTIFICATIONS_ENABLED=false
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@taskflow.app
