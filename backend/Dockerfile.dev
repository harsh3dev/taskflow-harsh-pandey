FROM golang:1.23

# golang:1.23 (Debian-based) ships with ca-certificates pre-installed and
# fully trusted, so no manual certificate setup is required.

# Install air for hot reload.
# GONOSUMDB skips the checksum DB lookup during build only — Docker Desktop's
# TLS proxy intercepts sum.golang.org during image builds on some Mac setups.
# This does NOT affect runtime TLS; SMTP will still do full certificate verification.
ENV GONOSUMDB=*
RUN go install github.com/air-verse/air@v1.61.7
ENV GONOSUMDB=

WORKDIR /app

# Pre-download dependencies so the module cache is warm before the source
# volume is mounted.  The cache is stored in a named volume so it persists
# across container restarts.
COPY go.mod go.sum ./
RUN go mod download

EXPOSE 8080

# Source is mounted at /app by docker-compose.override.yml.
# air watches for .go file changes and recompiles automatically.
CMD ["air"]
